generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id          String   @id
  name        String
  domain      String   @unique
  logoUrl     String?
  themeColors Json?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  guardians    GuardianUser[]
  transactions Transaction[]
  emailLogs    EmailLog[]
}

model GuardianUser {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String
  rut              String
  email            String?
  passwordHash     String
  lastLogin        DateTime?
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  transactions Transaction[]

  @@unique([tenantId, rut])
}

model AdminUser {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("SUPERADMIN") // SUPERADMIN, SUPPORT
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Transaction {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId           String
  guardianId         String    @db.Uuid
  buyOrder           String    @unique
  sessionId          String?
  tokenWs            String?   @unique
  amount             Int
  status             String    @default("PENDING") // PENDING, AUTHORIZED, REJECTED, FAILED
  authorizationCode  String?
  cardLastFour       String?
  paymentTypeCode    String?
  installmentsNumber Int?
  transactionDate    DateTime?
  edupayPayload      Json? // IDs de las cuotas/deudas pagadas en EduPay
  receiptItems       Json? // Snapshot legible de las cuotas para el comprobante
  edupaySynced       Boolean   @default(false)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant   Tenant       @relation(fields: [tenantId], references: [id])
  guardian GuardianUser @relation(fields: [guardianId], references: [id])
}

enum EmailType {
  PAYMENT_RECEIPT
  FORGOT_PASSWORD
  WELCOME
  SYSTEM
}

enum EmailStatus {
  SENT
  FAILED
  SIMULATED
}

model EmailLog {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String
  to        String
  subject   String
  type      EmailType
  status    EmailStatus
  error     String?
  createdAt DateTime    @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([createdAt])
  @@index([tenantId, createdAt])
  @@index([status, createdAt])
  @@index([type, createdAt])
}
